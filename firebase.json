{
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      "node_modules/**",
      ".git/**",
      "*.md"
    ],
    "cleanUrls": true,
    "redirects": [
      {
        "source": "/",
        "destination": "/app",
        "type": 302
      }
    ],
    "rewrites": [
      {
        "source": "/app",
        "destination": "/app.html"
      },
      {
        "source": "/app/**",
        "destination": "/app.html"
      }
    ],
    "headers": [
      {
        "source": "**/*.@(js|css)",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=3600"
          }
        ]
      },
      {
        "source": "**/*.@(png|jpg|jpeg|gif|svg|ico|webp)",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=86400"
          }
        ]
      }
    ]
  }
}
