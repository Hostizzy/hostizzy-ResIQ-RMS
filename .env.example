# ==============================================================================
# Supabase Configuration
# ==============================================================================
#
# PRODUCTION (Vercel):
#   Environment variables are already set in Vercel dashboard:
#   - VITE_SUPABASE_URL
#   - VITE_SUPABASE_ANON_KEY
#
# LOCAL DEVELOPMENT:
#   1. Copy this file: cp .env.example .env
#   2. Fill in your actual Supabase credentials below
#   3. Run: vercel dev (to test API endpoints locally)
#
# WHERE TO GET THESE VALUES:
#   - Supabase Dashboard → Settings → API
#   - Copy "Project URL" and "anon public" key
#
# NOTE: Both VITE_ prefixed and non-prefixed variables are supported
# ==============================================================================

# Option 1: VITE_ prefixed (matches Vercel production setup)
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here

# Option 2: Non-prefixed (also works)
# SUPABASE_URL=https://your-project-id.supabase.co
# SUPABASE_ANON_KEY=your_anon_key_here
