# Backend Configuration
# Copy this file to .env.local and fill in your values
# Then add these as Environment Variables in Vercel Dashboard:
# Project Settings → Environment Variables

# ============================================================
# Core — Database (Supabase)
# ============================================================
# Code accepts both SUPABASE_* and VITE_SUPABASE_* variable names.
SUPABASE_URL=https://dxthxsguqrxpurorpokq.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# ============================================================
# Core — Authentication (Firebase)
# ============================================================
# Project: resiq-by-hostizzy
FIREBASE_API_KEY=your_firebase_api_key_here
FIREBASE_AUTH_DOMAIN=resiq-by-hostizzy.firebaseapp.com
FIREBASE_PROJECT_ID=resiq-by-hostizzy
FIREBASE_STORAGE_BUCKET=resiq-by-hostizzy.firebasestorage.app
FIREBASE_MESSAGING_SENDER_ID=your_sender_id_here
FIREBASE_APP_ID=your_app_id_here
# Needed only by /api/auth-proxy for admin user create/delete
FIREBASE_SERVICE_ACCOUNT=paste_service_account_json_here

# ============================================================
# Cron jobs
# ============================================================
# Required for Vercel Cron to authenticate against /api/daily-summary
# and /api/send-push (broadcast action). Generate any long random string.
CRON_SECRET=generate_a_long_random_string

# ============================================================
# Gmail integration (daily summary email)
# ============================================================
GMAIL_CLIENT_ID=your_google_oauth_client_id
GMAIL_CLIENT_SECRET=your_google_oauth_client_secret
# Admin recipient for the daily summary email
DAILY_SUMMARY_EMAIL=admin@hostizzy.com
# Optional: sender alias for daily summary and target emails.
# Set this to a Gmail alias (configured in Gmail → Settings → Accounts → "Send mail as")
# so automated emails appear from a different address than guest communications.
# If unset, daily summaries send from the connected Gmail's primary address.
DAILY_SUMMARY_FROM_EMAIL=

# ============================================================
# WhatsApp Business — sending via Meta Cloud API
# ============================================================
WHATSAPP_ACCESS_TOKEN=permanent_token_from_meta_business
WHATSAPP_PHONE_ID=your_phone_number_id

# ============================================================
# Round 6 — Monthly Revenue Targets
# ============================================================
# Recipient of the dedicated target-progress email (separate from the
# admin daily summary). Defaults to stay@hostizzy.com if unset.
STAY_EMAIL_RECIPIENT=stay@hostizzy.com

# Name of the approved WhatsApp template for the daily target update
# (7 variables — see docs/REVENUE_TARGETS_SETUP.md for the exact body).
# If unset, the daily WA broadcast is skipped (email still sends).
WA_DAILY_TARGET_TEMPLATE=daily_sales_target_update
WA_DAILY_TARGET_LANGUAGE=en

# Optional: separate approved template used for tier-crossing celebrations.
# If unset, milestone crossings send email only (no WA).
WA_MILESTONE_TEMPLATE=tier_milestone_celebration

# ============================================================
# Round 6c — Web Push notifications
# ============================================================
# Generate a pair once with:  npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=BP...paste_public_key_here
VAPID_PRIVATE_KEY=paste_private_key_here
VAPID_SUBJECT=mailto:stay@hostizzy.com

# ============================================================
# Cloudinary (guest document uploads)
# ============================================================
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
