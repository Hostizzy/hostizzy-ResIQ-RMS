# Backend Configuration
# Copy this file to .env.local and fill in your values
# Then add these as Environment Variables in Vercel Dashboard:
# Project Settings → Environment Variables

# Supabase Configuration (Database)
# Code accepts both SUPABASE_* and VITE_SUPABASE_* variable names
SUPABASE_URL=https://dxthxsguqrxpurorpokq.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Firebase Configuration (Authentication)
# Project: resiq-by-hostizzy
FIREBASE_API_KEY=your_firebase_api_key_here
FIREBASE_AUTH_DOMAIN=resiq-by-hostizzy.firebaseapp.com
FIREBASE_PROJECT_ID=resiq-by-hostizzy
FIREBASE_STORAGE_BUCKET=resiq-by-hostizzy.firebasestorage.app
FIREBASE_MESSAGING_SENDER_ID=your_sender_id_here
FIREBASE_APP_ID=your_app_id_here
