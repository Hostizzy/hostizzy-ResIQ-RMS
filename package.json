  "description": "Property Management System for Vacation Rentals — TWA (Trusted Web Activity)",
  "main": "index.html",
  "scripts": {
    "twa:init": "npx @bubblewrap/cli init --manifest https://resiq.app/manifest.json",
    "twa:build": "npx @bubblewrap/cli build",
    "twa:update": "npx @bubblewrap/cli update --manifest https://resiq.app/manifest.json",
    "twa:validate": "npx @bubblewrap/cli validate --url https://resiq.app",
    "serve": "python3 -m http.server 8080",
    "generate-logos": "python3 generate-logos.py || bash generate-logos.sh"
  },
  "keywords": [
    "property-management",
    "vacation-rental",
    "pms",
    "hotel-management",
    "booking-system",
    "twa",
    "pwa"
