{
  "name": "resiq-by-hostizzy",
  "version": "1.0.0",
  "description": "Property Management System for Vacation Rentals — TWA (Trusted Web Activity)",
  "main": "index.html",
  "scripts": {
    "twa:init": "npx @bubblewrap/cli init --manifest https://resiq.hostizzy.com/manifest.json",
    "twa:build": "npx @bubblewrap/cli build",
    "twa:update": "npx @bubblewrap/cli update --manifest https://resiq.hostizzy.com/manifest.json",
    "twa:validate": "npx @bubblewrap/cli validate --url https://resiq.hostizzy.com",
    "build:prod": "node scripts/build.js",
    "build:fast": "node scripts/build.js --fast",
    "serve": "python3 -m http.server 8080"
  },
  "keywords": [
    "property-management",
    "vacation-rental",
    "pms",
    "hotel-management",
    "booking-system",
    "twa",
    "pwa"
  ],
  "author": "Hostizzy",
  "license": "UNLICENSED",
  "private": true,
  "dependencies": {
    "firebase-admin": "^12.0.0"
  },
  "devDependencies": {
    "javascript-obfuscator": "^5.3.0",
    "terser": "^5.46.0"
  }
}
